{
  "expo": {
    "name": "MESSAY",
    "slug": "messay-super-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.messay.app"
    },
    "android": {
      "package": "com.messay.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "INTERNET"
      ]
    },
    "web": {},
    "plugins": [
      "expo-router"
    ],
    "scheme": "messay",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "votre-project-id-ici"
      }
    }
  }
}
