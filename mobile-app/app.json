{
  "expo": {
    "name": "MESSAY",
    "slug": "messay-super-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.messay.app"
    },
    "android": {
      "package": "com.messay.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FF6B35"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "INTERNET"
      ]
    },
    "web": {},
    "plugins": [
      "expo-router"
    ],
    "scheme": "messay",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "441e60c6-bc1d-454e-aaa3-c9f2d73c4067"
      }
    }
  }
}
