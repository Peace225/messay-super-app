generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// AUTHENTIFICATION & UTILISATEURS
// ============================================

enum UserRole {
  USER
  CONDUCTEUR
  CHAUFFEUR
  ADMIN
  PARTENAIRE
  VENDEUR
}

enum MoyenPaiement {
  CARTE_BANCAIRE
  ORANGE_MONEY
  MTN_MOMO
  WAVE
  ESPECES
}

model User {
  id String @id @default(uuid())
  nom String
  prenom String?
  email String @unique
  telephone String @unique
  password String
  role UserRole @default(USER)
  photo String?
  moyenPaiement MoyenPaiement?
  isVerified Boolean @default(false)
  isBlocked Boolean @default(false)
  deviceToken String?
  otpCode String?
  otpExpiry DateTime?
  refreshToken String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses Course[]
  tickets Ticket[]
  billetsEvent BilletEvent[]
  commandesBTP CommandeBTP[]
  paiements Paiement[]
  supportTickets SupportTicket[]
  notifications Notification[]
  conducteurProfile Conducteur?
  chauffeurProfile Chauffeur?

  @@index([email])
  @@index([telephone])
  @@index([role])
}

// ============================================
// MOBILITÉ URBAINE - TRICYCLES
// ============================================

enum CourseStatus {
  EN_ATTENTE
  ACCEPTEE
  EN_COURS
  TERMINEE
  ANNULEE
}

enum TricycleStatus {
  DISPONIBLE
  EN_COURSE
  MAINTENANCE
  HORS_LIGNE
}

model Conducteur {
  id String @id @default(uuid())
  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  permis String
  numeroPermis String @unique
  vehiculeType String @default("TRICYCLE")
  immatriculation String @unique
  statut String @default("DISPONIBLE")
  disponible Boolean @default(true)
  positionLatitude Float?
  positionLongitude Float?
  note Float @default(5.0)
  nombreCourses Int @default(0)
  selfieVerification String?
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses Course[]
  tricycle Tricycle?

  @@index([statut])
  @@index([disponible])
  @@index([positionLatitude, positionLongitude])
}

model Tricycle {
  id String @id @default(uuid())
  immatriculation String @unique
  conducteurId String? @unique
  conducteur Conducteur? @relation(fields: [conducteurId], references: [id])
  modele String @default("TVS King")
  annee Int?
  batterie Int @default(100)
  vitesse Int @default(0)
  latitude Float @default(5.345)
  longitude Float @default(-4.024)
  status TricycleStatus @default(HORS_LIGNE)
  coursesAujourdhui Int @default(0)
  distanceParcourue Float @default(0)
  derniereActivite DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([conducteurId])
}

model Course {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  conducteurId String?
  conducteur Conducteur? @relation(fields: [conducteurId], references: [id])
  departLatitude Float
  departLongitude Float
  departAdresse String
  destinationLatitude Float
  destinationLongitude Float
  destinationAdresse String
  distance Float
  dureeEstimee Int
  prix Float
  statut CourseStatus @default(EN_ATTENTE)
  partageTrajet Boolean @default(false)
  noteConducteur Float?
  commentaire String?
  positionLiveLatitude Float?
  positionLiveLongitude Float?
  heureDebut DateTime?
  heureFin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([conducteurId])
  @@index([statut])
  @@index([createdAt])
}

// ============================================
// TRANSPORT INTERURBAIN
// ============================================

enum CompagnieTransport {
  UTB
  AVS
  SBTA
  TCI
  STIF
  CTE
  UTS
  AUTRE
}

enum TicketStatus {
  RESERVE
  PAYE
  UTILISE
  ANNULE
  EXPIRE
}

enum ClasseTicket {
  STANDARD
  VIP
  PREMIUM
}

enum CanalVente {
  GUICHET
  APP
  WEB
  AGENT
}

model Ticket {
  id String @id @default(uuid())
  userId String?
  user User? @relation(fields: [userId], references: [id])

  // Compagnie
  compagnie CompagnieTransport

  // Passager
  passagerNom String
  passagerPrenom String?
  telephone String
  email String?

  // Trajet
  depart String
  destination String
  gareDepart String?
  gareArrivee String?

  // Voyage
  dateDepart DateTime
  heureDepart String
  numeroBus String?
  siege String
  classe ClasseTicket @default(STANDARD)

  // Paiement
  prix Float
  methodePaiement MoyenPaiement?
  referencePaiement String?

  // QR & Statut
  qrCode String @unique
  statut TicketStatus @default(PAYE)
  codeValidation String? @unique
  dateValidation DateTime?

  // Metadata
  canalVente CanalVente @default(GUICHET)
  vendeurId String?
  paiementId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([qrCode])
  @@index([telephone])
  @@index([dateDepart])
  @@index([compagnie])
  @@index([statut])
}

// ============================================
// LOISIRS & ÉVÉNEMENTIEL
// ============================================

enum EventCategorie {
  CONCERT
  SPORT
  THEATRE
  CONFERENCE
  FESTIVAL
  AUTRE
}

model Event {
  id String @id @default(uuid())
  titre String
  description String
  categorie EventCategorie
  date DateTime
  heureDebut String
  lieu String
  adresse String
  latitude Float?
  longitude Float?
  prix Float
  image String?
  placesDisponibles Int
  placesTotal Int
  organisateur String
  isActif Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  billets BilletEvent[]

  @@index([date])
  @@index([categorie])
}

model BilletEvent {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  eventId String
  event Event @relation(fields: [eventId], references: [id])
  quantite Int @default(1)
  prixTotal Float
  qrCode String @unique
  statut String @default("VALIDE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([eventId])
}

// ============================================
// MODULE BTP - LACARRIÈRE
// ============================================

enum TypeMateriau {
  SABLE
  GRAVIER
  CIMENT
  PIERRE
  BETON
}

enum TypeCamion {
  BENNE
  CITERNE
  PLATEAU
  MALAXEUR
}

enum CommandeBTPStatus {
  EN_ATTENTE
  CONFIRMEE
  EN_ROUTE
  LIVREE
  ANNULEE
}

model CommandeBTP {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  typeMateriau TypeMateriau
  quantite Float
  unite String @default("TONNE")
  typeCamion TypeCamion
  adresseLivraison String
  latitudeLivraison Float
  longitudeLivraison Float
  dateLivraison DateTime
  heurePreferee String?
  prix Float
  statut CommandeBTPStatus @default(EN_ATTENTE)
  priorite Int @default(1)
  dateAssignation DateTime?
  chauffeurId String?
  chauffeur Chauffeur? @relation(fields: [chauffeurId], references: [id])
  camionId String?
  camion Camion? @relation(fields: [camionId], references: [id])
  positionLiveLatitude Float?
  positionLiveLongitude Float?
  etaMinutes Int?
  noteChauffeur Float?
  commentaire String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([chauffeurId])
  @@index([statut])
  @@index([priorite])
}

model Chauffeur {
  id String @id @default(uuid())
  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  permis String
  numeroPermis String @unique
  photo String?
  experience Int @default(0)
  notation Float @default(5.0)
  nombreLivraisons Int @default(0)
  statut String @default("DISPONIBLE")
  disponible Boolean @default(true)
  positionLatitude Float?
  positionLongitude Float?
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commandes CommandeBTP[]

  @@index([statut])
  @@index([disponible])
}

model Camion {
  id String @id @default(uuid())
  type TypeCamion
  capacite Float
  immatriculation String @unique
  marque String?
  modele String?
  annee Int?
  statut String @default("DISPONIBLE")
  disponible Boolean @default(true)
  positionLatitude Float?
  positionLongitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commandes CommandeBTP[]

  @@index([statut])
}

// ============================================
// PAIEMENTS
// ============================================

enum PaiementStatus {
  EN_ATTENTE
  REUSSI
  ECHOUE
  REMBOURSE
}

enum TypeTransaction {
  COURSE
  TICKET_TRANSPORT
  BILLET_EVENT
  COMMANDE_BTP
  RECHARGE
}

model Paiement {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  montant Float
  moyen MoyenPaiement
  typeTransaction TypeTransaction
  referenceId String
  statut PaiementStatus @default(EN_ATTENTE)
  transactionId String? @unique
  stripePaymentId String?
  recu String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([statut])
  @@index([typeTransaction])
}

// ============================================
// SUPPORT CLIENT
// ============================================

enum TypeDemande {
  QUESTION
  RECLAMATION
  OBJET_PERDU
  LITIGE
  TECHNIQUE
  AUTRE
}

enum SupportStatus {
  OUVERT
  EN_COURS
  RESOLU
  FERME
}

model SupportTicket {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  typeDemande TypeDemande
  sujet String
  message String
  statut SupportStatus @default(OUVERT)
  priorite String @default("NORMALE")
  assigneA String?
  reponse String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages SupportMessage[]

  @@index([userId])
  @@index([statut])
}

model SupportMessage {
  id String @id @default(uuid())
  ticketId String
  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId String
  senderRole String
  message String
  createdAt DateTime @default(now())

  @@index([ticketId])
}

// ============================================
// NOTIFICATIONS
// ============================================

enum NotificationType {
  COURSE
  TICKET
  EVENT
  BTP
  PAIEMENT
  SUPPORT
  SYSTEME
}

model Notification {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  type NotificationType
  titre String
  message String
  data String?
  isRead Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

// ============================================
// CONFIGURATION & TARIFS
// ============================================

model TarifCourse {
  id String @id @default(uuid())
  prixBase Float @default(500)
  prixParKm Float @default(200)
  prixParMinute Float @default(50)
  fraisService Float @default(0.15)
  isActif Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Configuration {
  id String @id @default(uuid())
  cle String @unique
  valeur String
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}